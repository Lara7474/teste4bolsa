          "data": {
            "type": "string"
          },
          "usuario": {
            "type": "string"
          },
          "de_status": {
            "type": "string"
          },
          "para_status": {
            "type": "string"
          },
          "responsavel": {
            "type": "string"
          },
          "observacao": {
            "type": "string"
          }
